{
  "name": "tc-blog",
  "title": "TC Blog",
  "version": "1.1.0",
  "homepage": "https://tautcony.github.io/",
  "author": "TautCony",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tautcony/tautcony.github.io",
    "owner": "tautcony",
    "name": "tautcony.github.io"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "eslint": "eslint ./ts",
    "typecheck": "tsc --noEmit",
    "submodule": "git submodule init && git submodule update",
    "build": "vite build",
    "build:dev": "vite build --mode development --watch",
    "sync:assets": "node scripts/sync-asset-data.mjs",
    "bundle": "bin/with-ruby bundle",
    "start": "bin/with-ruby bundle exec jekyll serve -H 127.0.0.1",
    "start:l": "bin/with-ruby bundle exec jekyll serve -l -H 127.0.0.1",
    "start:i": "bin/with-ruby bundle exec jekyll serve -I -H 127.0.0.1",
    "jekyll:build": "bin/with-ruby bundle exec jekyll build",
    "ci": "npm run eslint && npm run typecheck && npm run build && npm run jekyll:build"
  },
  "browserslist": [
    "defaults",
    "not IE 11",
    "not dead",
    "last 2 versions"
  ],
  "dependencies": {
    "@sentry/browser": "^8.54.0",
    "dat.gui": "^0.7.9",
    "heti": "^0.9.5",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@stylistic/eslint-plugin-js": "^3.0.1",
    "@stylistic/eslint-plugin-ts": "^3.0.1",
    "@types/dat.gui": "^0.7.13",
    "@types/node": "^22.13.1",
    "@typescript-eslint/parser": "^8.23.0",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "eslint": "^9.19.0",
    "eslint-plugin-import": "^2.31.0",
    "less": "^4.2.1",
    "sass": "^1.84.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0",
    "vite": "^5.4.14"
  }
}
