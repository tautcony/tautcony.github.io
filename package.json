{
  "name": "tc-blog",
  "title": "TC Blog",
  "version": "1.1.0",
  "homepage": "https://tautcony.github.io/",
  "author": "TautCony",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tautcony/tautcony.github.io",
    "owner": "tautcony",
    "name": "tautcony.github.io"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "eslint": "eslint ./ts",
    "typecheck": "tsc --noEmit",
    "sync:public": "node scripts/sync-public.mjs",
    "dev": "node scripts/sync-public.mjs && astro dev",
    "build": "node scripts/sync-public.mjs && astro build",
    "preview": "astro preview",
    "check:astro": "astro check",
    "lastmod:check": "node scripts/generate-lastmod.mjs --check",
    "lastmod": "node scripts/generate-lastmod.mjs --write-jekyll",
    "verify:routes:selftest": "node scripts/compare-routes.mjs --self-test",
    "verify:assets:selftest": "node scripts/compare-assets.mjs --self-test",
    "migrate:posts:selftest": "node scripts/migrate-posts.mjs --self-test",
    "migrate:posts": "node scripts/migrate-posts.mjs --write --freeze-lastmod",
    "migrate:posts:dry": "node scripts/migrate-posts.mjs --dry-run",
    "verify:routes:posts": "node scripts/compare-routes.mjs --scope posts --legacy mig/fixtures/legacy-post-urls.txt --dist dist",
    "verify:routes": "node scripts/compare-routes.mjs --scope all --legacy mig/fixtures/routes-jekyll.txt --dist dist",
    "verify:assets": "node scripts/compare-assets.mjs --legacy mig/fixtures/assets-jekyll.json --dist dist",
    "ci": "npm run eslint && npm run typecheck && npm run check:astro && npm run lastmod:check && npm run build && npm run verify:routes && npm run verify:assets && npm run verify:routes:selftest && npm run verify:assets:selftest && npm run migrate:posts:selftest",
    "dev:astro": "npm run dev",
    "build:astro": "npm run build",
    "preview:astro": "npm run preview",
    "ci:astro": "npm run ci"
  },
  "browserslist": [
    "defaults",
    "not IE 11",
    "not dead",
    "last 2 versions"
  ],
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/vue": "7.0.1",
    "@sentry/browser": "^8.54.0",
    "astro": "7.0.7",
    "dat.gui": "^0.7.9",
    "heti": "^0.9.5",
    "js-yaml": "5.2.1",
    "rehype-raw": "7.0.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "vue": "3.5.24"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@stylistic/eslint-plugin-js": "^3.0.1",
    "@stylistic/eslint-plugin-ts": "^3.0.1",
    "@types/dat.gui": "^0.7.13",
    "@types/js-yaml": "4.0.9",
    "@types/node": "^22.13.1",
    "@typescript-eslint/parser": "^8.23.0",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "eslint": "^9.19.0",
    "eslint-plugin-import": "^2.31.0",
    "sass": "^1.84.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0",
    "vite": "^5.4.14"
  }
}
