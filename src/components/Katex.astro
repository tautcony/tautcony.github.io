---
import { site } from "../data/site";

interface Props {
    /** Explicit false skips KaTeX (matches page.math: false). */
    math?: boolean;
}

const { math } = Astro.props;
const enabled = site.katex && math !== false;
---

{
    enabled && (
        <>
            <link
                rel="stylesheet"
                href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.21/katex.min.css"
                integrity="sha384-6eyFPx0bmoXi1OWcjcisxZLrexBw4Rq1+mSJBDwyTfOKP9iEetT7sNb9w975urwW"
                crossorigin="anonymous"
                referrerpolicy="no-referrer"
            />
            <script
                defer
                src="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.21/katex.min.js"
                integrity="sha384-D3SoHAvonuutgll1YBhV6qHHPJpZojZ4MHuDbZjDaCE7GuZF1ywUlB8XnpFMI2sG"
                crossorigin="anonymous"
                referrerpolicy="no-referrer"
                is:inline
            />
            <script
                defer
                src="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.21/contrib/auto-render.min.js"
                integrity="sha384-XCTqnt7gdFa4F/tvy9lWNDTLOeRZij3ZpKB/8ktV5t87PD6NXxde1GnJMq/jO1su"
                crossorigin="anonymous"
                referrerpolicy="no-referrer"
                is:inline
            />
            <script is:inline>
                document.addEventListener("DOMContentLoaded", function () {
                    if (typeof renderMathInElement !== "function") {
                        return;
                    }
                    renderMathInElement(document.body, {
                        delimiters: [
                            { left: "$$", right: "$$", display: true },
                            { left: "\\[", right: "\\]", display: true },
                            { left: "\\(", right: "\\)", display: false },
                            { left: "$", right: "$", display: false },
                        ],
                        throwOnError: false,
                        ignoredTags: ["script", "noscript", "style", "textarea", "pre", "code"],
                    });
                });
            </script>
        </>
    )
}
