---
/**
 * Static `.pdf-embed`: one idle placeholder + hidden mount shell.
 * Posts usually emit the idle shell in markdown; rehype injects the same
 * `.pdf-embed__mount`. Client replaces the placeholder with mount children on click.
 *
 * @see src/lib/pdf-embed.ts
 * @see src/client/features/pdf-embed.ts
 */
import { cssLength, pdfOpenUrl } from "../lib/pdf-embed";

interface Props {
    file: string;
    height?: string | number;
    title?: string;
    label?: string;
}

const {
    file,
    height = 500,
    title = "PDF document",
    label = "PDF 预览",
} = Astro.props;

const fileUrl = pdfOpenUrl(file);
const heightCss = cssLength(height);
---

<div
    class="pdf-embed"
    data-pdf-file={fileUrl}
    data-pdf-height={String(height)}
    data-pdf-title={title}
    style={`min-height: ${heightCss}`}
>
    <div class="pdf-embed__placeholder">
        <p class="pdf-embed__label">{label}</p>
        <button type="button" class="pdf-embed__button">打开 PDF 预览</button>
        <p class="pdf-embed__alt">
            <a href={fileUrl} target="_blank" rel="noopener">直接下载 / 打开 PDF</a>
        </p>
    </div>
    <div class="pdf-embed__mount" hidden>
        <object
            class="pdf-embed__viewer"
            type="application/pdf"
            title={title}
            aria-label={title}
            style={`height: ${heightCss}`}
        >
            <p class="pdf-embed__nosupport">
                当前浏览器不支持内嵌 PDF 预览 ·{" "}
                <a href={fileUrl} target="_blank" rel="noopener">直接打开 / 下载 PDF</a>
            </p>
        </object>
        <p class="pdf-embed__alt pdf-embed__actions">
            <a href={fileUrl} target="_blank" rel="noopener">在新窗口打开 / 下载 PDF</a>
        </p>
    </div>
</div>
