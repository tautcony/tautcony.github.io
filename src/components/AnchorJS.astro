---
import { site } from "../data/site";
---

{
    site.anchorjs && (
        <>
            <script is:inline>
                function async(url, func) {
                    var script = document.createElement("script"),
                        orgins = document.getElementsByTagName("script")[0];
                    script.src = url;
                    if (func) {
                        script.addEventListener(
                            "load",
                            function (e) {
                                func(null, e);
                            },
                            false
                        );
                    }
                    orgins.parentNode.insertBefore(script, orgins);
                }
            </script>
            <script is:inline>
                async(
                    "https://cdnjs.cloudflare.com/ajax/libs/anchor-js/4.2.2/anchor.min.js",
                    function () {
                        anchors.options = {
                            visible: "always",
                            placement: "right",
                            icon: "¶",
                        };
                        anchors
                            .add()
                            .remove(".intro-header h1")
                            .remove(".subheading")
                            .remove(".sidebar-container h5");
                    }
                );
            </script>
            <style is:global>
                @media all and (min-width: 800px) {
                    .anchorjs-link {
                        position: absolute;
                        left: -1em;
                        font-size: 1.1em;
                    }
                }
            </style>
        </>
    )
}
