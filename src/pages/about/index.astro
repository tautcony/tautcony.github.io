---
import PageLayout from "../../layouts/PageLayout.astro";
import Comment from "../../components/Comment.astro";
import { pageMeta } from "../../data/pages";
import { KON_BLOCKS, KON_META } from "../../data/kon";
import { getAllPosts } from "../../lib/posts";

const allPosts = await getAllPosts();
const meta = pageMeta.about;
---

<PageLayout
    title={meta.title}
    description={meta.description}
    headerImg={meta.headerImg}
    pageUrl={meta.path}
    allPosts={allPosts}
>
    <div id="player1" class="aplayer" style="float: right;"></div>

    <!-- Options + quote blocks SSG; preferred language + hide/show via client/features/about -->
    <select id="langSelect">
        {
            KON_BLOCKS.map((block, index) => (
                <option value={String(index)}>{block.title}</option>
            ))
        }
    </select>
    <div id="kon-container">
        {
            KON_BLOCKS.map((block, index) => (
                <div
                    class={index === 0 ? KON_META.className : `${KON_META.className} none`}
                    title={block.title}
                    lang={block.lang}
                >
                    <blockquote>{block.blockquote}</blockquote>
                    {block.content.map(line => (
                        <p>{line}</p>
                    ))}
                    <p style="text-align: right;" title={KON_META.title}>
                        ——{" "}
                        <a href={KON_META.url}>{KON_META.title}</a>
                    </p>
                </div>
            ))
        }
    </div>

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/aplayer/1.10.1/APlayer.min.css"
        integrity="sha512-CIYsJUa3pr1eoXlZFroEI0mq0UIMUqNouNinjpCkSWo3Bx5NRlQ0OuC6DtEB/bDqUWnzXc1gs2X/g52l36N5iw=="
        crossorigin="anonymous"
        referrerpolicy="no-referrer"
    />
    <script
        src="https://cdnjs.cloudflare.com/ajax/libs/aplayer/1.10.1/APlayer.min.js"
        integrity="sha512-RWosNnDNw8FxHibJqdFRySIswOUgYhFxnmYO3fp+BgCU7gfo4z0oS7mYFBvaa8qu+axY39BmQOrhW3Tp70XbaQ=="
        crossorigin="anonymous"
        referrerpolicy="no-referrer"
        is:inline></script>
    <script is:inline>
        var ap = new APlayer({
            element: document.getElementById("player1"),
            mini: false,
            autoplay: true,
            mutex: true,
            theme: "#e6d0b2",
            preload: "metadata",
            listMaxHeight: "365px",
            audio: {
                name: "あの日の夢",
                artist: "百石元",
                url: "/attach/bgm/ano-hi-no-yume.m4a",
                cover: "/attach/bgm/ano-hi-no-yume.jpg",
            },
        });
        ap.volume(0.75);
    </script>

    <Comment />
</PageLayout>
