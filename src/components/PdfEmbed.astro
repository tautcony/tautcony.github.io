---
/**
 * Static PDF embed placeholder matching pdf-embed.ts / Jekyll include contract.
 * Prefer pre-baked HTML from migrate-posts for posts; this component is for pages.
 */
interface Props {
    file: string;
    height?: string | number;
    title?: string;
    label?: string;
}

const {
    file,
    height = 500,
    title = "PDF document",
    label = "PDF 预览",
} = Astro.props;

const fileUrl = file.startsWith("/") || /^https?:/i.test(file) ? file : `/${file}`;
---

<div
    class="pdf-embed"
    data-pdf-file={fileUrl}
    data-pdf-height={String(height)}
    data-pdf-title={title}
>
    <div class="pdf-embed__placeholder">
        <p class="pdf-embed__label">{label}</p>
        <button type="button" class="pdf-embed__button">打开 PDF 预览</button>
        <p class="pdf-embed__alt">
            <a href={fileUrl} target="_blank" rel="noopener">直接下载 / 打开 PDF</a>
        </p>
    </div>
</div>
