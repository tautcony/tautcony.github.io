{
  "name": "tc-blog",
  "title": "TC Blog",
  "version": "1.1.0",
  "homepage": "https://tautcony.github.io/",
  "author": "TautCony",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tautcony/tautcony.github.io",
    "owner": "tautcony",
    "name": "tautcony.github.io"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "eslint": "eslint ./ts",
    "typecheck": "tsc --noEmit",
    "tslint": "npm run typecheck",
    "submodule": "git submodule init && git submodule update",
    "build:dev": "webpack --config build/webpack.dev.conf.js",
    "build:prod": "webpack --config build/webpack.prod.conf.js",
    "build:update": "webpack --config build/webpack.update.conf.js",
    "build": "npm run build:prod && npm run build:update",
    "bundle": "bin/with-ruby bundle",
    "start": "bin/with-ruby bundle exec jekyll serve -I -H 127.0.0.1",
    "start:l": "bin/with-ruby bundle exec jekyll serve -I -l -H 127.0.0.1",
    "jekyll:build": "bin/with-ruby bundle exec jekyll build",
    "ci": "npm run typecheck && npm run build && npm run jekyll:build"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-conventional-changelog"
    }
  },
  "browserslist": [
    "defaults",
    "not IE 11",
    "not dead",
    "last 2 versions"
  ],
  "dependencies": {
    "@babel/runtime-corejs3": "^7.26.7",
    "@sentry/browser": "^8.54.0",
    "animejs": "^3.2.2",
    "axios": "^1.7.9",
    "core-js": "^3.40.0",
    "dat.gui": "^0.7.9",
    "heti": "^0.9.5",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@babel/core": "^7.26.7",
    "@babel/plugin-transform-runtime": "^7.25.9",
    "@babel/preset-env": "^7.26.7",
    "@eslint/js": "^9.19.0",
    "@stylistic/eslint-plugin-js": "^3.0.1",
    "@stylistic/eslint-plugin-ts": "^3.0.1",
    "@types/animejs": "^3.1.13",
    "@types/dat.gui": "^0.7.13",
    "@types/node": "^22.13.1",
    "@types/webpack": "^5.28.5",
    "@typescript-eslint/parser": "^8.23.0",
    "@vue/babel-helper-vue-jsx-merge-props": "^1.4.0",
    "@vue/babel-plugin-jsx": "^1.2.5",
    "@vue/babel-preset-jsx": "^1.4.0",
    "acorn": "^8.14.0",
    "ajv": "^8.17.1",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^9.2.1",
    "css-loader": "^7.1.2",
    "cssnano": "^7.0.6",
    "eslint": "^9.19.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-webpack-plugin": "^4.2.0",
    "less": "^4.2.1",
    "less-loader": "^12.2.0",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss": "^8.5.1",
    "postcss-loader": "^8.1.1",
    "postcss-preset-env": "^10.1.3",
    "sass": "^1.84.0",
    "sass-loader": "^16.0.4",
    "terser-webpack-plugin": "^5.3.11",
    "ts-loader": "^9.5.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0",
    "webpack": "^5.97.1",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-merge": "^6.0.1",
    "webpackbar": "^7.0.0"
  }
}
