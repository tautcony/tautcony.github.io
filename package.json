{
  "name": "tc-blog",
  "title": "TC Blog",
  "version": "1.1.0",
  "homepage": "https://tautcony.github.io/",
  "author": "TautCony",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tautcony/tautcony.github.io",
    "owner": "tautcony",
    "name": "tautcony.github.io"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "eslint": "eslint .",
    "lint": "npm run eslint",
    "typecheck": "tsc --noEmit",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check:astro": "astro check",
    "math:check": "node scripts/content/check-math-delimiters.mjs",
    "lastmod:check": "node scripts/content/generate-lastmod.mjs --check",
    "lastmod:refresh": "node scripts/content/generate-lastmod.mjs --refresh",
    "verify:routes:selftest": "node scripts/test/compare-routes.mjs --self-test",
    "verify:assets:selftest": "node scripts/test/compare-assets.mjs --self-test",
    "verify:routes:posts": "node scripts/test/compare-routes.mjs --scope posts --legacy mig/fixtures/legacy-post-urls.txt --dist dist",
    "verify:routes": "node scripts/test/compare-routes.mjs --scope all --legacy mig/fixtures/routes-jekyll.txt --dist dist",
    "verify:assets": "node scripts/test/compare-assets.mjs --legacy mig/fixtures/assets-jekyll.json --dist dist",
    "eval:consistency": "node scripts/test/eval-consistency.mjs",
    "eval:consistency:selftest": "node scripts/test/eval-consistency.mjs --self-test",
    "eval:visual": "node scripts/test/eval-visual.mjs",
    "eval:all": "npm run eval:consistency && npm run eval:visual",
    "ci": "npm run eslint && npm run typecheck && npm run check:astro && npm run math:check && npm run lastmod:check && npm run build",
    "verify:legacy": "npm run verify:routes && npm run verify:assets"
  },
  "browserslist": [
    "defaults",
    "not IE 11",
    "not dead",
    "last 2 versions"
  ],
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/markdown-remark": "7.2.1",
    "@sentry/browser": "^10.65.0",
    "astro": "7.0.9",
    "dat.gui": "^0.7.9",
    "heti": "^0.9.6",
    "js-yaml": "5.2.1",
    "rehype-raw": "7.0.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/dat.gui": "^0.7.13",
    "@types/js-yaml": "4.0.9",
    "@types/node": "^22.20.1",
    "@types/three": "^0.185.1",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "sass": "^1.101.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4"
  }
}
