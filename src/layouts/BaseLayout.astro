---
/**
 * Root shell: head, nav, main, footer, and main-site client entry.
 * Site styles live under `src/styles/` (visual contract).
 */
import "../styles/tc-blog.scss";
// Prefer heti's published CSS — packaging SCSS still uses deprecated @import / global builtins.
import "heti/umd/heti.min.css";
import Head from "../components/Head.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";

interface Props {
    title?: string;
    description?: string;
    subtitle?: string;
    headerImg?: string;
    feature?: boolean;
    pageUrl?: string;
    bodyClass?: string;
    /** Draft / private preview pages — robots noindex. */
    noindex?: boolean;
}

const props = Astro.props;
---

<!DOCTYPE html>
<html lang={site.lang} dir="ltr">
    <Head {...props} />
    <!-- Empty ontouchstart enables :active styles on iOS Safari -->
    <body ontouchstart="" class={props.bodyClass}>
        <Nav />
        <main id="main-content">
            <slot />
        </main>
        <Footer />
        <!-- Zero-size image retained for WeChat link-preview thumbnail behavior -->
        <img
            src={`${site.baseurl}/img/icon_wechat.png`}
            width="0"
            height="0"
            alt=""
            role="presentation"
            loading="eager"
            decoding="async"
            fetchpriority="low"
        />
        <!-- Browser-only entry (never import from frontmatter — SSG will break) -->
        <script>
            import "../client/entries/blog.ts";
        </script>
    </body>
</html>
