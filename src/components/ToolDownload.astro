---
interface Props {
    owner: string;
    repo: string;
    width: "wide" | "middle" | "narrow";
}

const { owner, repo, width } = Astro.props;
const displayName = repo.replace(/-/g, "");
---

{/* Tool list is static — render immediately; script only fills latest version. */}
<a
    class={width}
    href={`https://github.com/${owner}/${repo}/releases`}
    target="_blank"
    rel="noopener"
    data-latest-release
    data-owner={owner}
    data-repo={repo}
>
    <span class="icon" aria-hidden="true"></span>
    {displayName}
    <br />
    version <span class="release-version" data-release-version>…</span>
    <span data-release-date></span>
</a>
